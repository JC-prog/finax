# ── Gemini (Google AI Studio) ──────────────────────────────────────────────
GOOGLE_API_KEY=

# ── NewsData.io ────────────────────────────────────────────────────────────
NEWSDATA_API_KEY=
# Comma-separated tickers and keywords to monitor
WATCH_TICKERS=AAPL,TSLA,NVDA,MSFT
WATCH_KEYWORDS=earnings,fed,inflation,rate hike

# ── Telegram ───────────────────────────────────────────────────────────────
# Create a bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=
# Your user ID or group chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=

# ── Email (SMTP) ───────────────────────────────────────────────────────────
# For Gmail: enable 2FA and generate a 16-char App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=your@gmail.com
# Comma-separated list of recipient addresses
EMAIL_TO=recipient@example.com

# ── Schedule ───────────────────────────────────────────────────────────────
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=Asia/Singapore
